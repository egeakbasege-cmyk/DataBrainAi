# ── AI ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Database (Supabase — Transaction mode port 6543) ──────────────────
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Redis (Upstash) ───────────────────────────────────────────────────
REDIS_URL=rediss://default:password@xxx.upstash.io:6379

# ── Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-min-32-char-random-string-here
NEXTAUTH_URL=https://your-app.vercel.app

# ── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── App ───────────────────────────────────────────────────────────────
APP_ENV=production
RATE_LIMIT_PER_HOUR=10
CACHE_TTL_SECONDS=3600
BACKEND_URL=https://starcoins-api.fly.dev

# ── Sentry (optional) ─────────────────────────────────────────────────
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
