generator client {
  provider = "prisma-client-js"
}

// H-04: switched to PostgreSQL — SQLite crashes on Vercel serverless because
// the filesystem is read-only. Set DATABASE_URL in Vercel env (Neon, Supabase,
// or Railway all work). For local dev set DATABASE_URL to your local Postgres or
// a Neon branch connection string.
//
// After changing DATABASE_URL run:
//   npx prisma migrate dev --name init
//   npx prisma generate
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth.js Standard Tables ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("USER")
  isPro         Boolean   @default(false)
  stripeEmail   String?
  accounts        Account[]
  sessions        Session[]
  analyses        Analysis[]
  kairosAnalyses  KairosAnalysis[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// --- Sail AI Domain Models ---
// PostgreSQL: metrics and output use native Json type instead of String

model Analysis {
  id          String   @id @default(cuid())
  userId      String?
  isAnonymous Boolean  @default(false)
  sector      String
  metrics     Json     // native PostgreSQL JSON — no more double-stringify
  output      Json     // native PostgreSQL JSON — no more double-stringify
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([userId])
}

model AnonymousUsage {
  id            String   @id @default(cuid())
  fingerprintId String   @unique
  usageCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- KAIROS Data Lab Models ---

enum KairosPlatform {
  SHOPIFY
  AMAZON
}

enum KairosStatus {
  PENDING
  SCRAPING
  ANALYZING
  COMPLETE
  ERROR
}

model KairosAnalysis {
  id         String         @id @default(cuid())
  userId     String?
  platform   KairosPlatform
  targetUrl  String
  targetName String         @default("")
  status     KairosStatus   @default(PENDING)
  rawData    Json           @default("{}")
  aiAnalysis Json           @default("{}")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([platform])
  @@index([createdAt(sort: Desc)])
}

model KairosCachedProduct {
  id                    String         @id @default(cuid())
  asinOrHandle          String         @unique
  platform              KairosPlatform
  title                 String
  price                 Float?
  imageUrl              String?
  supplierEstimatedCost Float?
  rating                Float?
  reviewCount           Int?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([asinOrHandle])
  @@index([platform])
}
