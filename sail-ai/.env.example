# ── Database (PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/sail_ai_db"

# ── Auth.js v5 ────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET="your_generated_auth_secret_here"
AUTH_URL="https://your-deployment.vercel.app"   # local: http://localhost:3000

# ── Google OAuth (optional — leave blank to disable Google sign-in) ───
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ── Google Gemini AI ──────────────────────────────────────────────────
GEMINI_API_KEY="AIza..."

# ── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PRICE_ID="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# ── Optional ──────────────────────────────────────────────────────────
# Paste a Slack/Discord webhook URL to receive feedback submissions
FEEDBACK_WEBHOOK_URL=""
# Your app's public URL (used for CORS in middleware)
NEXT_PUBLIC_APP_URL="https://your-deployment.vercel.app"
