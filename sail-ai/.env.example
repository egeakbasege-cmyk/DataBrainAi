# ─────────────────────────────────────────────────────────────────────────────
# VERCEL FRONTEND
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth.js v5 ────────────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET="your_generated_auth_secret_here"
AUTH_URL="https://your-app.vercel.app"          # local: http://localhost:3000

# ── Google OAuth (optional — remove to disable Google sign-in) ────────────────
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PRICE_ID="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# ── Public app URL (CORS, redirects) ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── Optional: Slack/Discord webhook for feedback submissions ──────────────────
FEEDBACK_WEBHOOK_URL=""

# ─────────────────────────────────────────────────────────────────────────────
# RAILWAY BACKEND  (set these in Vercel env vars too — frontend needs the URL)
# ─────────────────────────────────────────────────────────────────────────────

# Vercel uses this to proxy all AI requests to Railway
RAILWAY_BACKEND_URL="https://your-service.up.railway.app"

# ─────────────────────────────────────────────────────────────────────────────
# RAILWAY BACKEND env vars  (set in Railway project settings, not Vercel)
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic Claude (AI provider — called only from Railway) ─────────────────
ANTHROPIC_API_KEY="sk-ant-..."
# Recommended model for strategy work; override per use-case if needed
ANTHROPIC_MODEL="claude-opus-4-5"

# ── Supabase (Benchmark Engine + session memory) ──────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # server-side only — never expose to browser

# ── Database (Postgres via Supabase or Railway-provisioned) ───────────────────
DATABASE_URL="postgresql://user:password@db.your-project.supabase.co:5432/postgres"

# ── Railway internal ──────────────────────────────────────────────────────────
PORT="8080"
NODE_ENV="production"
