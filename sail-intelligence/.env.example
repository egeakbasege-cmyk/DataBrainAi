# ─────────────────────────────────────────────────────────────────────────────
# SAIL INTELLIGENCE — Environment Variables
# Copy to .env and fill in all values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=                            # openssl rand -hex 32
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sail_intelligence
POSTGRES_USER=sail
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://sail:CHANGE_ME@localhost:5432/sail_intelligence

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=sail-intelligence

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=                            # openssl rand -hex 32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OAuth 2.0 ─────────────────────────────────────────────────────────────────
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# ── AES-256 Vault ─────────────────────────────────────────────────────────────
VAULT_ENCRYPTION_KEY=                      # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Apify ─────────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=
APIFY_DEFAULT_TIMEOUT_SECS=120
APIFY_MAX_RETRIES=4

# ── LLM Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# ── Proxy ─────────────────────────────────────────────────────────────────────
RESIDENTIAL_PROXY_URL=
PROXY_ROTATION_ENABLED=true

# ── Alerting ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WHATSAPP_WEBHOOK_URL=
ALERT_ANOMALY_THRESHOLD=2.5

# ── Cron Schedules ────────────────────────────────────────────────────────────
SAIL_MODE_CRON=0 2 * * *
YACHT_MODE_CRON=*/15 * * * *

# ── Per-Connector Rate Limits (req/min) ───────────────────────────────────────
RATE_LIMIT_AMAZON=20
RATE_LIMIT_EBAY=30
RATE_LIMIT_TIKTOK=15
RATE_LIMIT_META_ADS=25
RATE_LIMIT_SPOTIFY=20

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_HITL_ENFORCEMENT=true
ENABLE_CAPTCHA_HANDLING=true
ENABLE_PROXY_ROTATION=true
LOG_LEVEL=INFO
